<%
  # Configurações dinâmicas sem JS
  current_mode = params[:mode] == 'flag' ? 'flag' : 'reveal'
  face_emoji = @game.state == 'lost' ? '😵' : (@game.state == 'won' ? '😎' : '🙂')
  
  # Cálculo de tempo (Server-side)
  time_elapsed = if @game.finished_at
                   (@game.finished_at - @game.started_at).to_i
                 elsif @game.started_at
                   (Time.current - @game.started_at).to_i
                 else
                   0
                 end

  # Cores dos números
  number_colors = ['', '#0000ff', '#008000', '#ff0000', '#000080', '#800000', '#008080', '#000000', '#808080']
  
  # Agrupamento das células por linha para montar a tabela
  grid = @game.cells.order(:row, :col).group_by(&:row)
%>

<div class="flex-1 relative p-2 sm:p-10 flex items-center justify-center">
  <div class="bg-[#c0c0c0] win95-outset flex flex-col select-none shadow-xl max-w-full max-h-full">
    
    <!-- Barra de Título -->
    <div class="bg-[#0000a8] text-white px-1 py-[2px] flex justify-between items-center text-[13px] font-bold h-[20px]">
      <div class="flex items-center gap-1 ml-1">
        <span class="text-[10px] mt-[1px]">💣</span>
        <span class="tracking-wide">Minesweeper</span>
      </div>
      <div class="flex gap-[2px] mr-[1px]">
        <%= link_to "X", games_path, class: "win95-outset bg-[#c0c0c0] text-black w-[16px] h-[14px] flex items-center justify-center text-[9px] font-bold no-underline" %>
      </div>
    </div>

    <!-- Controles de Modo (Workaround para não usar JS no Botão Direito) -->
    <div class="px-2 py-1 bg-[#c0c0c0] text-xs flex gap-4 border-b border-[#808080]">
      <span class="font-bold">Current Tool:</span>
      <%= link_to "⛏️ Dig (Click to switch)", game_path(@game, mode: 'reveal'), class: "px-2 py-[2px] #{current_mode == 'reveal' ? 'win95-inset bg-[#dfdfdf]' : 'win95-outset hover:bg-[#dfdfdf]'}" %>
      <%= link_to "🚩 Flag (Click to switch)", game_path(@game, mode: 'flag'), class: "px-2 py-[2px] #{current_mode == 'flag' ? 'win95-inset bg-[#dfdfdf]' : 'win95-outset hover:bg-[#dfdfdf]'}" %>
    </div>

    <!-- Corpo do Jogo -->
    <div class="p-[6px] pb-1 border-[3px] border-t-[#808080] border-l-[#808080] border-r-white border-b-white bg-[#c0c0c0] flex-1 flex flex-col">
      
      <!-- Placar Superior -->
      <div class="win95-inset bg-[#c0c0c0] p-1 mb-[6px] flex justify-between items-center h-[42px]">
        <div class="bg-black text-[#ff0000] font-digital text-[34px] px-1 win95-inset w-[60px] h-[30px] flex items-center justify-center leading-none">
          <span class="mt-1"><%= @game.mines.to_s.rjust(3, '0') %></span>
        </div>
        
        <%= button_to games_path(game: { difficulty: @game.difficulty }), method: :post, class: "win95-outset bg-[#c0c0c0] w-[26px] h-[26px] flex items-center justify-center text-sm active:win95-inset" do %>
          <span class="mt-[2px] ml-[1px]"><%= face_emoji %></span>
        <% end %>

        <div class="bg-black text-[#ff0000] font-digital text-[34px] px-1 win95-inset w-[60px] h-[30px] flex items-center justify-center leading-none">
          <span class="mt-1"><%= time_elapsed.to_s.rjust(3, '0') %></span>
        </div>
      </div>

      <!-- Tabela do Jogo -->
      <div class="win95-inset bg-[#c0c0c0] overflow-auto flex-1 flex items-start justify-center p-1">
        <table class="border-collapse bg-[#c0c0c0]" style="border-spacing: 0;">
          <tbody>
            <% grid.keys.sort.each do |row_index| %>
              <tr class="leading-[0]">
                <% grid[row_index].sort_by(&:col).each do |cell| %>
                  <td class="p-0">
                    <% if cell.state == 'hidden' %>
                      <!-- Célula Escondida: Faz um POST para o controller com a ação Dig ou Flag -->
                      <%= button_to "", play_game_path(@game), 
                          params: { row: cell.row, col: cell.col, action_type: current_mode }, 
                          method: :post, 
                          class: "w-[24px] h-[24px] min-w-[24px] min-h-[24px] win95-cell-hidden block" %>
                    
                    <% elsif cell.state == 'flagged' %>
                      <!-- Célula com Bandeira: Clicar remove a bandeira (unflag) -->
                      <%= button_to "🚩", play_game_path(@game), 
                          params: { row: cell.row, col: cell.col, action_type: 'unflag' }, 
                          method: :post, 
                          class: "w-[24px] h-[24px] min-w-[24px] min-h-[24px] win95-cell-hidden flex items-center justify-center text-[12px]" %>
                    
                    <% else %>
                      <!-- Célula Revelada -->
                      <div class="w-[24px] h-[24px] min-w-[24px] min-h-[24px] win95-cell-revealed bg-[#c0c0c0] flex items-center justify-center font-bold text-[16px] pb-[1px] <%= 'bg-[#ff0000]' if cell.is_mine %>">
                        <% if cell.is_mine %>
                          💣
                        <% elsif cell.neighbor_mines > 0 %>
                          <span style="color: <%= number_colors[cell.neighbor_mines] %>">
                            <%= cell.neighbor_mines %>
                          </span>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    
    <div class="flex gap-[2px] px-[3px] pb-[3px] bg-[#c0c0c0]">
      <div class="win95-inset h-[20px] flex-1 px-2 flex items-center text-[11px]">
        Clicks: <%= @game.clicks %>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Vitória: Aparece automaticamente se o estado for won -->
<% if @game.state == 'won' %>
  <div class="fixed inset-0 flex items-center justify-center z-50 px-4 bg-black/20">
    <div class="bg-[#c0c0c0] win95-outset w-full max-w-[320px] shadow-xl">
      <div class="bg-[#0000a8] text-white px-1 py-[2px] flex justify-between items-center text-[13px] font-bold">
        <span>You Win!</span>
      </div>
      <div class="p-4 flex flex-col gap-4 text-sm">
        <p>
          Congratulations! You cleared the <strong><%= @game.difficulty %></strong> level in <%= time_elapsed %> seconds!<br><br>
          Please enter your name for the high scores.
        </p>
        
        <%= form_with model: Score.new, url: scores_path, local: true do |f| %>
          <%= f.hidden_field :game_id, value: @game.id %>
          <%= f.text_field :player_name, class: "win95-inset bg-white text-black px-2 py-1 outline-none w-full mb-4", placeholder: "Anonymous", autofocus: true %>
          <div class="flex justify-center">
            <%= f.submit "Save Score", class: "win95-outset bg-[#c0c0c0] px-8 py-1 focus:outline-none active:win95-inset cursor-pointer font-bold" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>