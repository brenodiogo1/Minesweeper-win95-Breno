<div class="flex-1 relative p-10">
  
  <!-- Ícone na Área de Trabalho -->
  <div class="w-16 flex flex-col items-center cursor-pointer mb-4">
    <div class="text-3xl mb-1">💣</div>
    <div class="text-white text-xs bg-[#0000a8] px-1 text-center select-none">Minesweeper</div>
  </div>

  <!-- Janela do Menu Principal -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="bg-[#c0c0c0] win95-outset flex flex-col shadow-xl w-[320px]">
      
      <!-- Título da Janela -->
      <div class="bg-[#0000a8] text-white px-2 py-[2px] flex justify-between items-center text-[13px] font-bold h-[24px]">
        <div class="flex items-center gap-1">
          <span class="text-[12px]">💣</span>
          <span class="tracking-wide">Minesweeper - New Game</span>
        </div>
        <div class="win95-outset bg-[#c0c0c0] text-black w-[16px] h-[14px] flex items-center justify-center text-[10px] font-bold">X</div>
      </div>

      <div class="p-6 flex flex-col gap-4 text-center">
        <p class="text-sm font-bold mb-2">Select Difficulty:</p>
        
        <!-- Formulários Nativos Rails (Sem JS) para criar um novo jogo -->
        <%= button_to "Beginner (9x9, 10 Mines)", games_path(game: { difficulty: 'beginner' }), method: :post, class: "win95-outset bg-[#c0c0c0] px-4 py-2 w-full text-left font-bold active:win95-inset hover:bg-[#dfdfdf] cursor-pointer" %>
        
        <%= button_to "Intermediate (16x16, 40 Mines)", games_path(game: { difficulty: 'intermediate' }), method: :post, class: "win95-outset bg-[#c0c0c0] px-4 py-2 w-full text-left font-bold active:win95-inset hover:bg-[#dfdfdf] cursor-pointer" %>
        
        <%= button_to "Expert (16x30, 99 Mines)", games_path(game: { difficulty: 'expert' }), method: :post, class: "win95-outset bg-[#c0c0c0] px-4 py-2 w-full text-left font-bold active:win95-inset hover:bg-[#dfdfdf] cursor-pointer" %>

        <div class="h-[2px] border-t border-[#808080] border-b border-[#ffffff] my-2"></div>
        
        <!-- Link para Ranking -->
        <%= link_to "View High Scores", scores_path, class: "text-sm text-blue-800 underline hover:text-blue-600" %>
      </div>

    </div>
  </div>
</div>