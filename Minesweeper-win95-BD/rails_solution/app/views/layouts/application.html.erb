<!DOCTYPE html>
<html>
  <head>
    <title>Minesweeper Win95 - No JS</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Tailwind CDN para garantir que as classes funcionem direto no seu Rails -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">

    <style>
      body {
        background-color: #008080; /* Classic Win95 desktop */
        color: #000;
      }
      .font-digital { font-family: 'VT323', monospace; }
      .win95-bg { background-color: #c0c0c0; }
      
      .win95-outset {
        border-style: solid;
        border-width: 3px;
        border-color: #ffffff #808080 #808080 #ffffff;
      }
      .win95-inset {
        border-style: solid;
        border-width: 3px;
        border-color: #808080 #ffffff #ffffff #808080;
      }
      .win95-cell-hidden {
        background-color: #c0c0c0;
        border-style: solid;
        border-width: 3px;
        border-color: #ffffff #808080 #808080 #ffffff;
      }
      .win95-cell-hidden:active {
        border-width: 1px;
        border-color: #808080;
      }
      .win95-cell-revealed {
        background-color: #c0c0c0;
        border: 1px solid #808080;
        border-bottom-color: #c0c0c0;
        border-right-color: #c0c0c0;
      }
    </style>
  </head>

  <body>
    <!-- Desktop Wrapper -->
    <div class="min-h-screen font-sans flex flex-col overflow-hidden">
      <%= yield %>
      
      <!-- Barra de Tarefas Win95 -->
      <div class="fixed bottom-0 left-0 right-0 h-[28px] bg-[#c0c0c0] border-t-2 border-t-[#ffffff] flex items-center px-1 z-40" style="box-shadow: inset 0 1px 0 rgba(255,255,255,0.8)">
        <div class="win95-outset bg-[#c0c0c0] flex items-center gap-[6px] px-2 pb-[2px] h-[22px] font-bold text-[12px]">
          <span>Start</span>
        </div>
        <div class="w-[1px] h-[20px] bg-[#808080] border-r border-[#ffffff] mx-1"></div>
        <div class="flex-1 flex gap-1 px-1">
          <div class="flex items-center gap-1 px-2 h-[22px] min-w-[120px] win95-inset bg-[#dfdfdf] text-xs font-bold">
            <span class="text-sm mt-[2px]">💣</span>
            <span class="truncate pt-[1px]">Minesweeper</span>
          </div>
        </div>
        <div class="win95-inset h-[22px] px-2 flex items-center bg-[#c0c0c0] text-xs pb-[1px] gap-2 ml-auto">
          <span><%= Time.current.strftime("%I:%M %p") %></span>
        </div>
      </div>
    </div>
  </body>
</html>